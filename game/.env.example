NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173
SERVE_CLIENT=true

# LOCAL DEV DEFAULT:
# Работает без Docker/PostgreSQL. Данные сохраняются в server/.data/local-db.json.
DB_DRIVER=local
LOCAL_DB_FILE=server/.data/local-db.json

# PRODUCTION / RENDER:
# На Render поставь DB_DRIVER=postgres и DATABASE_URL из Render Postgres.
# DB_DRIVER=postgres
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# PG_SSL=true
PG_POOL_SIZE=10

# Server world-state rate. 20 is much lighter than 30 and still feels responsive with client interpolation.
TICK_RATE=20
# Client network updates. The server simulates at TICK_RATE but replicates deltas at this rate.
NETWORK_RATE=10
